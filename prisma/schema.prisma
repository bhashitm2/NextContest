// CP Contest Portal — Prisma schema (v0.1 "The Wedge")
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Platform {
  CODEFORCES
  LEETCODE
  ATCODER
  CODECHEF
  HACKERRANK // reserved for a later release
  // v1.1 additions (append-only — never reorder a Postgres enum)
  GEEKSFORGEEKS
  CODE360
}

enum ContestStatus {
  UPCOMING
  ONGOING
  FINISHED
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) adapter models
// Standard @auth/prisma-adapter schema. Sessions kept for flexibility even
// though v0.1 uses the JWT session strategy.
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  // Secret token for the user's personal subscribable contest calendar feed
  // (GET /api/calendar/<token>.ics). Generated lazily on first subscribe.
  calendarToken String?   @unique
  // Public slug for the shareable profile page (GET /u/<username>). Set by the
  // user during profile setup; null until chosen.
  username      String?   @unique
  // IANA timezone (e.g. "Asia/Kolkata") captured from the browser, so reminder
  // emails (rendered server-side, in UTC) can show times in the user's zone.
  timezone      String?

  accounts Account[]
  sessions Session[]
  bookmarks Bookmark[]
  handles  PlatformHandle[]
  subscriptions PlatformSubscription[]
  tombstones CalendarTombstone[]
  sentRequests     Friendship[] @relation("SentRequests")
  receivedRequests Friendship[] @relation("ReceivedRequests")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Domain models
// ---------------------------------------------------------------------------

model Contest {
  id              String        @id @default(cuid())
  platform        Platform
  externalId      String // the platform's own contest identifier
  title           String
  url             String
  startTime       DateTime
  endTime         DateTime
  durationSeconds Int
  difficulty      String?
  status          ContestStatus @default(UPCOMING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  bookmarks Bookmark[]
  tombstones CalendarTombstone[]

  @@unique([platform, externalId]) // dedupe key for upserts
  @@index([startTime])
  @@index([status, startTime])
}

model Bookmark {
  id            String    @id @default(cuid())
  userId        String
  contestId     String
  notify24h     Boolean   @default(true)
  notify1h      Boolean   @default(true)
  notified24hAt DateTime? // set once the 24h reminder is sent (idempotency)
  notified1hAt  DateTime? // set once the 1h reminder is sent (idempotency)
  auto          Boolean   @default(false) // created by a PlatformSubscription, not manually
  createdAt     DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([contestId])
}

// Records a contest a user UN-followed / un-bookmarked, so the calendar feed
// can keep emitting it as STATUS:CANCELLED until it ends. Subscribed calendar
// apps (especially Google) only remove an event when they see a cancellation,
// not when it silently disappears from the feed. Pruned once the contest ends.
model CalendarTombstone {
  id        String   @id @default(cuid())
  userId    String
  contestId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([contestId])
}

// "Follow a platform": auto-reminders for every upcoming contest on it, no
// manual bookmarking. Drives auto-created Bookmarks (see server/sync/auto-bookmarks).
model PlatformSubscription {
  id        String   @id @default(cuid())
  userId    String
  platform  Platform
  notify24h Boolean  @default(true)
  notify1h  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

// v0.5 (handle connect + Codolio-style verification + cross-platform stats).
model PlatformHandle {
  id               String    @id @default(cuid())
  userId           String
  platform         Platform
  handle           String
  rating           Int? // current rating
  maxRating        Int? // peak rating
  rank             String? // platform title, e.g. "Expert", "5★", "Cyan"
  problemsSolved   Int? // headline count (cheap cross-platform aggregation)
  // Rich payload: { difficulty:{easy,medium,hard}, contests, recentSolved:[…],
  // solvedByMonth:[{month,count}], … }. Shape = ProfileStats.extra.
  stats            Json?
  verified         Boolean   @default(false)
  verificationCode String?
  // Compile-error verification (alternative to the bio-token method): the pinned
  // challenge problem key (CF "4-A" / AtCoder "abc086_a") + when it was issued.
  verifyProblem    String?
  verifyStartedAt  DateTime?
  lastSynced       DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

// v0.6 social layer. One row per ordered (requester→addressee) pair; a PENDING
// row is a friend request, ACCEPTED is a friendship. "Friends of X" = ACCEPTED
// rows where X is requester OR addressee.
model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  respondedAt DateTime?

  requester User @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("ReceivedRequests", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// v0.6 Phase 3. Caches the AI-written head-to-head verdict for a pair of users.
// `pairKey` = the two user ids sorted + joined (direction-independent, so both
// viewers share one cache). Regenerated only when `statsHash` changes or the row
// is >24h old, to respect the Gemini free-tier rate limit.
model ComparisonVerdict {
  id        String   @id @default(cuid())
  pairKey   String   @unique
  statsHash String
  verdict   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// v1.0 per-contest compare. Caches one user's finalized performance (rank +
// rating change) on a single rated contest. Results are IMMUTABLE once a
// contest is rated, so a row never needs refreshing — keyed by handle (not
// userId) so the cache is reusable across the viewer/friend roles and survives
// handle changes. Only successful ("ok") fetches are cached; the pending /
// not-participated / unavailable states are transient and re-checked each view.
model ContestResult {
  id             String   @id @default(cuid())
  platform       Platform
  externalId     String // matches Contest.externalId
  handle         String // lowercased platform handle
  rank           Int?
  ratingBefore   Int?
  ratingAfter    Int?
  ratingDelta    Int?
  problemsSolved Int?
  performance    Int?
  fetchedAt      DateTime @default(now())

  @@unique([platform, externalId, handle])
  @@index([platform, externalId])
}

// Tracks per-source pipeline health so the UI can show a "stale data" banner
// and the founder can be alerted on scraper failure.
model SyncState {
  source           Platform  @id
  lastRunAt        DateTime?
  lastSuccessAt    DateTime?
  lastError        String?
  contestsUpserted Int       @default(0)
  updatedAt        DateTime  @updatedAt
}
